# =============================================================================
# Agentic AI System - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# =============================================================================

# =============================================================================
# SYSTEM CONFIGURATION (REQUIRED)
# =============================================================================

# Flask secret key - MUST be set in production! Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Flask environment: production | development
FLASK_ENV=production
FLASK_DEBUG=false

# Web interface
WEB_INTERFACE_HOST=0.0.0.0
WEB_INTERFACE_PORT=5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Primary database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///data/agentic.db
# DATABASE_URL=postgresql://user:password@localhost:5432/agentic_ai

# Credential database (always encrypted)
CREDENTIAL_DB_PATH=data/credentials.db
CREDENTIAL_MASTER_PASSWORD=change-this-master-password

# Redis (recommended for production)
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your-redis-password

# =============================================================================
# LLM PROVIDERS (at least one required)
# =============================================================================

# LLM7 - Free public API (no key needed for free tier)
LLM7_API_KEY=llm7-free-api-key
LLM7_BASE_URL=https://api.llm7.com/v1

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_ORG_ID=org-...

# CAMEL AI
# CAMEL_API_KEY=...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace
# HUGGINGFACE_TOKEN=hf_...

# =============================================================================
# PLATFORM INTEGRATIONS (optional)
# =============================================================================

# GitHub
# GITHUB_TOKEN=ghp_...
# GITHUB_USERNAME=your-username

# Google Services
# GOOGLE_CLIENT_ID=...googleusercontent.com
# GOOGLE_CLIENT_SECRET=...

# Netlify
# NETLIFY_SITE_ID=...
# NETLIFY_CLIENT_SECRET=...

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
ENCRYPTION_ALGORITHM=AES-256

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

MAX_CONCURRENT_AGENTS=10
AGENT_TIMEOUT=300
ENABLE_DYNAMIC_AGENTS=true
DEFAULT_AI_MODEL=gpt-3.5-turbo
MAX_TOKENS=2048
TEMPERATURE=0.7

# =============================================================================
# SCHEDULER AND SYNC
# =============================================================================

ENABLE_SCHEDULER=true
ENABLE_SYNC_ENGINE=true
ENABLE_WEB_INTERFACE=true

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE_PATH=logs/agentic.log
ENABLE_METRICS=true

# =============================================================================
# EMAIL NOTIFICATIONS (optional)
# =============================================================================

# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=...
# SMTP_PASSWORD=...
